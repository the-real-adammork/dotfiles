#!/usr/bin/env bash
set -euo pipefail

usage() {
    echo "usage: $(basename "$0") <input.pdf>" >&2
}

if [[ $# -ne 1 ]]; then
    usage
    exit 1
fi

input="$1"

if [[ ! -f "$input" ]]; then
    echo "error: file not found: $input" >&2
    exit 1
fi

input_name="$(basename "$input")"
extension="${input_name##*.}"
extension_lower="$(printf '%s' "$extension" | tr '[:upper:]' '[:lower:]')"

if [[ "$extension_lower" != "pdf" ]]; then
    echo "error: expected a .pdf file: $input" >&2
    exit 1
fi

input_dir="$(cd "$(dirname "$input")" && pwd)"
output="$input_dir/${input_name%.*}.md"
managed_python="${PDF_TO_MARKDOWN_PYTHON:-$HOME/.local/share/dotfiles/pdf-to-markdown/bin/python}"

python_code='
import pathlib
import sys

import pymupdf4llm

input_path = sys.argv[1]
output_path = pathlib.Path(sys.argv[2])
markdown = pymupdf4llm.to_markdown(input_path)
output_path.write_text(markdown, encoding="utf-8")
'

convert_with_python() {
    local python_bin="$1"

    "$python_bin" -c "import pymupdf4llm" >/dev/null 2>&1 || return 1
    "$python_bin" -c "$python_code" "$input" "$output"
}

if [[ -n "${PDF_TO_MARKDOWN_PYTHON:-}" ]]; then
    if [[ ! -x "$PDF_TO_MARKDOWN_PYTHON" ]]; then
        echo "error: PDF_TO_MARKDOWN_PYTHON is not executable: $PDF_TO_MARKDOWN_PYTHON" >&2
        exit 1
    fi
    if ! convert_with_python "$PDF_TO_MARKDOWN_PYTHON"; then
        echo "error: PDF_TO_MARKDOWN_PYTHON cannot import pymupdf4llm: $PDF_TO_MARKDOWN_PYTHON" >&2
        exit 1
    fi
elif [[ -x "$managed_python" ]] && convert_with_python "$managed_python"; then
    :
elif command -v python3 >/dev/null 2>&1 && convert_with_python "$(command -v python3)"; then
    :
elif command -v uv >/dev/null 2>&1; then
    uv run --quiet --with pymupdf4llm --with pymupdf python -c "$python_code" "$input" "$output"
else
    echo "error: no PDF Markdown converter found. Run ./install.sh or install uv/pymupdf4llm." >&2
    exit 1
fi

echo "wrote $output"
