      "Bash(awk:*)",
      "Bash(md5:*)",
      "Bash(shasum:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(pip3:*)",
      "Bash(pip:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(sqlite3:*)",
      "Bash(gh:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(/usr/bin/git status:*)",
      "Bash(/usr/bin/git diff:*)",
