      "Bash(git shortlog:*)",
      "Bash(git describe:*)",
      "Bash(git name-rev:*)",
      "Bash(git reflog:*)",
      "Bash(git -C:*)",
      "Bash(git add:*)",
      "Bash(git fetch:*)",
      "Bash(git worktree:*)",
      "Bash(git merge:*)",
      "Bash(git pull:*)",
      "Bash(git stash:*)",
      "Bash(git rebase:*)",
      "Bash(git cherry-pick:*)",
      "Bash(/usr/bin/git show:*)",
      "Bash(/usr/bin/git blame:*)",
      "Bash(/usr/bin/git branch:*)",
      "Bash(/usr/bin/git remote:*)",
      "Bash(/usr/bin/git tag:*)",
      "Bash(/usr/bin/git rev-parse:*)",
      "Bash(/usr/bin/git rev-list:*)",
      "Bash(/usr/bin/git ls-files:*)",
      "Bash(/usr/bin/git cat-file:*)",
      "Bash(/usr/bin/git shortlog:*)",
      "Bash(/usr/bin/git describe:*)",
      "Bash(/usr/bin/git name-rev:*)",
      "Bash(/usr/bin/git reflog:*)",
      "Bash(/usr/bin/git -C:*)",
      "Bash(/usr/bin/git add:*)",
      "Bash(/usr/bin/git fetch:*)",
      "Bash(/usr/bin/git worktree:*)",
      "Bash(/usr/bin/git merge:*)",
      "Bash(/usr/bin/git pull:*)",
      "Bash(/usr/bin/git stash:*)",
      "Bash(/usr/bin/git rebase:*)",
      "Bash(/usr/bin/git cherry-pick:*)",
      "Bash(cd:*)",
      "Bash(compound command contains cd with output redirection)",
      "Bash(command contains ambiguous syntax with command separators)",
      "Bash(command contains shell metacharacters)",
      "mcp__jcodemunch__*",
      "mcp__pencil"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Bash(cat */.env)",
      "Bash(source */.env)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jcodemunch-mcp hook-event create"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jcodemunch-mcp hook-event remove"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "github",
        "repo": "nextlevelbuilder/ui-ux-pro-max-skill"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true
}
