# Font
font-family = "Monaspace Neon"
font-family-bold = "Monaspace Xenon"
font-family-italic = "Monaspace Radon"
font-family-bold-italic = "Monaspace Krypton"
# font-style = "Medium"
# font-style-bold = "Italic"
# font-style-italic = "Italic"
# font-style-bold-italic = "Regular"
font-size = 11

# Monaspace advanced features
font-feature = calt
font-feature = liga
font-feature = ss01
font-feature = ss02
font-feature = ss03
font-feature = ss04
font-feature = ss05
font-feature = ss06
font-feature = ss07
font-feature = ss08
font-feature = ss09
font-feature = ss10

# Window
window-padding-x = 4
window-padding-y = 4

# Theme
theme = Catppuccin Latte
