# Low-risk read-only and local inspection commands mirrored from Claude settings.
prefix_rule(pattern = ["ls"], decision = "allow")
prefix_rule(pattern = ["find"], decision = "allow")
prefix_rule(pattern = ["cat"], decision = "allow")
prefix_rule(pattern = ["head"], decision = "allow")
prefix_rule(pattern = ["tail"], decision = "allow")
prefix_rule(pattern = ["wc"], decision = "allow")
prefix_rule(pattern = ["file"], decision = "allow")
prefix_rule(pattern = ["stat"], decision = "allow")
prefix_rule(pattern = ["tree"], decision = "allow")
prefix_rule(pattern = ["du"], decision = "allow")
prefix_rule(pattern = ["df"], decision = "allow")
prefix_rule(pattern = ["which"], decision = "allow")
prefix_rule(pattern = ["type"], decision = "allow")
prefix_rule(pattern = ["realpath"], decision = "allow")
prefix_rule(pattern = ["basename"], decision = "allow")
prefix_rule(pattern = ["dirname"], decision = "allow")
prefix_rule(pattern = ["pwd"], decision = "allow")
prefix_rule(pattern = ["whoami"], decision = "allow")
prefix_rule(pattern = ["uname"], decision = "allow")
prefix_rule(pattern = ["date"], decision = "allow")
prefix_rule(pattern = ["env"], decision = "allow")
prefix_rule(pattern = ["echo"], decision = "allow")
prefix_rule(pattern = ["printf"], decision = "allow")
prefix_rule(pattern = ["diff"], decision = "allow")
prefix_rule(pattern = ["sort"], decision = "allow")
prefix_rule(pattern = ["uniq"], decision = "allow")
prefix_rule(pattern = ["jq"], decision = "allow")
prefix_rule(pattern = ["sed"], decision = "allow")
prefix_rule(pattern = ["awk"], decision = "allow")
prefix_rule(pattern = ["md5"], decision = "allow")
prefix_rule(pattern = ["shasum"], decision = "allow")
prefix_rule(pattern = ["sqlite3"], decision = "allow")
prefix_rule(pattern = ["gh"], decision = "allow")
prefix_rule(pattern = ["curl"], decision = "allow")
prefix_rule(pattern = ["wget"], decision = "allow")

# Local file operations that remain constrained by Codex sandboxing.
prefix_rule(pattern = ["mkdir"], decision = "allow")
prefix_rule(pattern = ["touch"], decision = "allow")
prefix_rule(pattern = ["cp"], decision = "allow")
prefix_rule(pattern = ["mv"], decision = "allow")
prefix_rule(pattern = ["chmod"], decision = "allow")
prefix_rule(pattern = ["tar"], decision = "allow")
prefix_rule(pattern = ["zip"], decision = "allow")
prefix_rule(pattern = ["unzip"], decision = "allow")
prefix_rule(pattern = ["tee"], decision = "allow")
prefix_rule(pattern = ["xargs"], decision = "allow")

# Language and package tooling from the Claude allow list.
prefix_rule(pattern = ["python3"], decision = "allow")
prefix_rule(pattern = ["python"], decision = "allow")
prefix_rule(pattern = ["pip3"], decision = "allow")
prefix_rule(pattern = ["pip"], decision = "allow")
prefix_rule(pattern = ["node"], decision = "allow")
prefix_rule(pattern = ["npm"], decision = "allow")
prefix_rule(pattern = ["npx"], decision = "allow")

# Git commands Claude was configured to allow.
prefix_rule(pattern = ["git", ["status", "diff", "log", "show", "blame", "branch", "remote", "tag", "rev-parse", "rev-list", "ls-files", "cat-file", "shortlog", "describe", "name-rev", "reflog", "-C", "add", "fetch", "worktree", "merge", "pull", "stash", "rebase", "cherry-pick"]], decision = "allow")
prefix_rule(pattern = ["/usr/bin/git", ["status", "diff", "log", "show", "blame", "branch", "remote", "tag", "rev-parse", "rev-list", "ls-files", "cat-file", "shortlog", "describe", "name-rev", "reflog", "-C", "add", "fetch", "worktree", "merge", "pull", "stash", "rebase", "cherry-pick"]], decision = "allow")

# Keep secret files blocked even if another rule would otherwise match.
prefix_rule(pattern = ["cat", ".env"], decision = "forbidden", justification = "Do not read .env files; ask the user for needed non-secret values.")
prefix_rule(pattern = ["source", ".env"], decision = "forbidden", justification = "Do not source .env files; ask the user for needed non-secret values.")
prefix_rule(pattern=["strings"], decision="allow")
prefix_rule(pattern=["codex", "mcp"], decision="allow")
