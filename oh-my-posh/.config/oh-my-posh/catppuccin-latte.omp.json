{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "os": "#ACB0BE",
    "pink": "#ea76cb",
    "lavender": "#7287FD",
    "blue": "#1e66f5",
    "text": "#4c4f69",
    "white": "#eff1f5",
    "surface": "#ccd0da"
  },
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "p:blue",
          "foreground": "p:white",
          "leading_diamond": "\ue0b6",
          "style": "diamond",
          "powerline_symbol": "\ue0b4",
          "template": " {{.Icon}} ",
          "type": "os"
        },
        {
          "background": "p:blue",
          "foreground": "p:white",
          "powerline_symbol": "\ue0b4",
          "style": "powerline",
          "template": "{{ .UserName }}@{{ .HostName }} ",
          "type": "session"
        },
        {
          "background": "p:pink",
          "foreground": "p:white",
          "powerline_symbol": "\ue0b4",
          "properties": {
            "folder_icon": "..\ue5fe..",
            "home_icon": "~",
            "style": "agnoster_short"
          },
          "style": "powerline",
          "template": " {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "p:lavender",
          "foreground": "p:white",
          "powerline_symbol": "\ue0b4",
          "properties": {
            "branch_icon": "\ue725 ",
            "cherry_pick_icon": "\ue29b ",
            "commit_icon": "\uf417 ",
            "fetch_status": false,
            "fetch_upstream_icon": false,
            "merge_icon": "\ue727 ",
            "no_commits_icon": "\uf0c3 ",
            "rebase_icon": "\ue728 ",
            "revert_icon": "\uf0e2 ",
            "tag_icon": "\uf412 "
          },
          "style": "powerline",
          "template": " {{ .HEAD }} ",
          "trailing_diamond": "\ue0b4",
          "type": "git"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 4
}
